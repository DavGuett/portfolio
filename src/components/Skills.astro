---
// src/components/Skills.astro
const skillGroups = [
    {
        title: "Desenvolvimento Full Stack",
        description: "Criação de APIs robustas e interfaces reativas.",
        skills: [".NET 8", "C#", "Vue.js", "PostgreSQL", "Entity Framework"]
    },
    {
        title: "DevOps & Infraestrutura",
        description: "Foco em automação, containers e deploy contínuo.",
        skills: ["Docker", "CI/CD Pipelines", "Linux (Kubuntu/Fedora)", "AWS", "SRE Practices"]
    },
    {
        title: "Segurança & Ferramentas",
        description: "Gestão de identidade e ferramentas de produtividade.",
        skills: ["Keycloak", "IdentityServer", "Git", "Postman", "Agile/Scrum"]
    }
];
---

<section id="skills" class="py-16 border-t border-slate-800">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {skillGroups.map(group => (
                <div class="flex flex-col gap-4 p-6 rounded-2xl bg-slate-900/50 border border-slate-800 hover:border-indigo-500/50 transition-colors">
                    <div class="h-10 w-10 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400 mb-2">
                        {/* Você pode trocar por ícones SVG específicos depois */}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>

                    <h3 class="text-xl font-bold text-white">{group.title}</h3>
                    <p class="text-sm text-slate-400">{group.description}</p>

                    <div class="flex flex-wrap gap-2 mt-auto pt-4">
                        {group.skills.map(skill => (
                                <span class="px-2 py-1 text-xs font-medium rounded-md bg-slate-800 text-slate-300 border border-slate-700">
              {skill}
            </span>
                        ))}
                    </div>
                </div>
        ))}
    </div>
</section>